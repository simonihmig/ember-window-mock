{
  "private": true,
  "repository": "https://github.com/simonihmig/ember-window-mock.git",
  "license": "MIT",
  "author": "Simon Ihmig <simon.ihmig@gmail.com>",
  "scripts": {
    "lint": "yarn workspaces run lint",
    "lint:fix": "yarn workspaces run lint:fix",
    "start": "concurrently 'yarn:start:*' --restart-after 5000 --prefix-colors cyan,white,yellow",
    "start:test-app": "yarn workspace test-app run start",
    "test": "yarn workspaces run test",
    "test:ember": "yarn workspace test-app run test:ember",
    "release": "yarn release-it"
  },
  "devDependencies": {
    "@release-it-plugins/lerna-changelog": "8.0.1",
    "@release-it-plugins/workspaces": "5.0.3",
    "concurrently": "10.0.3",
    "prettier": "3.8.5",
    "release-it": "19.2.4"
  },
  "workspaces": [
    "ember-window-mock",
    "test-app"
  ],
  "engines": {
    "node": "18.* || >= 20"
  },
  "resolutions": {
    "@glimmer/component": "2.1.1"
  },
  "release-it": {
    "plugins": {
      "@release-it-plugins/lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": true
      },
      "@release-it-plugins/workspaces": true
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "tokenRef": "GITHUB_AUTH"
    },
    "npm": false
  },
  "version": "2.0.0"
}
